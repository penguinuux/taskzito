# REPORTING ENGINE (Relatório por dia e tags)
# ==============================================================================
def parse_journal_for_report():
    """
    Lê o journal.md e extrai todas as tags do tipo #Task e #Bug.
    Retorna uma estrutura organizada.
    """
    if not os.path.exists(JOURNAL_FILE):
        return {}
        
    with open(JOURNAL_FILE, 'r', encoding='utf-8') as f:
        lines = f.read().splitlines()
        
    report_data = {}
    current_date = None
    current_notes = []
    
    for line in lines:
        if line.strip().startswith('# '):
            if current_date and current_notes:
                process_notes_for_report(current_date, current_notes, report_data)
            
            date_match = re.match(r'^#\s+(\d{2}/\d{2}/\d{4})', line.strip())
            if date_match:
                current_date = date_match.group(1)
            else:
                current_date = None
            current_notes = []
            continue
            
        if current_date:
            note_match = re.match(r'^\s*[-*]\s+\[(\d{2}:\d{2}:\d{2})\]\s+(.*)$', line)
            if note_match:
                time_str, text = note_match.groups()
                current_notes.append({
                    'time': time_str,
                    'text': text
                })
            else:
                if current_notes:
                    line_clean = line.replace('\\n', '\n')
                    current_notes[-1]['text'] += "\n" + line_clean
                    
    if current_date and current_notes:
        process_notes_for_report(current_date, current_notes, report_data)
        
    return report_data

def process_notes_for_report(date_str, notes_list, report_data):
    """Auxiliar para extrair as tags das notas de um dia e salvar no report_data."""
    for note in notes_list:
        note_text = note['text']
        timestamp = note['time']
        
        note_text = note_text.replace('\\n', '\n')
        tags = re.findall(r'#(Task\w+|Bug\w+)', note_text, re.IGNORECASE)
        
        for tag in tags:
            tag_type = "Task" if tag.lower().startswith("task") else "Bug"
            tag_id = tag[len(tag_type):]
            normalized_tag = f"#{tag_type}{tag_id}"
            
            if date_str not in report_data:
                report_data[date_str] = {}
            if normalized_tag not in report_data[date_str]:
                report_data[date_str][normalized_tag] = []
                
            report_data[date_str][normalized_tag].append((timestamp, note_text.strip()))

def generate_report(simple=False):
    """Gera e exibe um relatório de tasks e bugs resolvidos por dia."""
    report_data = parse_journal_for_report()
    
    if not report_data:
        if simple:
            print("Nenhum registro de #Task ou #Bug encontrado.")
        else:
            print(Style.paint(f"\n{ICON_REPORT} {Style.BOLD}RELATÓRIO DE TASKS E BUGS EXECUTADOS{Style.RESET}", Style.CYAN))
            print(Style.paint("═" * 60, Style.CYAN))
            print(Style.paint("  Nenhum registro de #Task ou #Bug encontrado em seu jornal.", Style.MUTED))
            print(Style.paint("  Para gerar um relatório, marque suas notas no diário. Exemplo:", Style.MUTED))
            print(Style.paint(f"  taskzito note \"Finalizado o setup do banco de dados #Task42282\"", Style.YELLOW))
            print(Style.paint("═" * 60, Style.CYAN))
        return
        
    sorted_dates = sorted(report_data.keys(), key=lambda d: datetime.strptime(d, "%d/%m/%Y"))
    
    if simple:
        for date_str in sorted_dates:
            tags_dict = report_data[date_str]
            sorted_tags = sorted(tags_dict.keys(), key=lambda t: (0 if "Task" in t else 1, t))
            tags_str = ", ".join(sorted_tags)
            print(f"{date_str}: {tags_str}")
    else:
        print(Style.paint(f"\n{ICON_REPORT} {Style.BOLD}RELATÓRIO DE TASKS E BUGS EXECUTADOS{Style.RESET}", Style.CYAN))
        print(Style.paint("═" * 60, Style.CYAN))
        
        for date_str in sorted_dates:
            print(f"\n{ICON_CALENDAR} {Style.paint(date_str, Style.WHITE, bold=True)}")
            print(Style.paint("  " + "─" * 45, Style.MUTED))
            
            tags_dict = report_data[date_str]
            sorted_tags = sorted(tags_dict.keys(), key=lambda t: (0 if "Task" in t else 1, t))
            
            for tag in sorted_tags:
                is_bug = "Bug" in tag
                tag_color = Style.RED if is_bug else Style.PURPLE
                tag_icon = ICON_BUG if is_bug else ICON_TASK
                
                print(f"    {tag_icon} {Style.paint(tag, tag_color, bold=True)}")
                
                for timestamp, note_text in tags_dict[tag]:
                    time_display = Style.paint(f"[{timestamp}]", Style.MUTED)
                    highlighted_note = highlight_tags(note_text)
                    note_lines = highlighted_note.split('\n')
                    print(f"      {ICON_TIME} {time_display} {note_lines[0]}")
                    indentation = " " * 19
                    for extra_line in note_lines[1:]:
                        print(f"{indentation}{extra_line}")
            print()
            
        print(Style.paint("═" * 60, Style.CYAN))


# ==============================================================================
# DASHBOARD (Interface de Entrada Padrão)
# ==============================================================================
def show_dashboard():
    """Exibe um painel de controle premium consolidando o status de hoje."""
    now = datetime.now()
    date_display = now.strftime("%A, %d de %B de %Y - %H:%M:%S")
    # Traduz dia da semana de forma simples se possível (opcional, mantendo portabilidade rápida)
    weekdays_pt = {
        "Monday": "Segunda-feira", "Tuesday": "Terça-feira", "Wednesday": "Quarta-feira",
        "Thursday": "Quinta-feira", "Friday": "Sexta-feira", "Saturday": "Sábado", "Sunday": "Domingo"
    }
    months_pt = {
        "January": "Janeiro", "February": "Fevereiro", "March": "Março", "April": "Abril",
        "May": "Maio", "June": "Junho", "July": "Julho", "August": "Agosto",
        "September": "Setembro", "October": "Outubro", "November": "Novembro", "December": "Dezembro"
    }
    
    eng_weekday = now.strftime("%A")
    eng_month = now.strftime("%B")
    
    pt_weekday = weekdays_pt.get(eng_weekday, eng_weekday)
    pt_month = months_pt.get(eng_month, eng_month)
    date_display = f"{pt_weekday}, {now.day} de {pt_month} de {now.year}"
    
    print("\n" + Style.paint("  ⚡  TASKZITO  ⚡  ", Style.PURPLE, bold=True).center(68))
    print(Style.paint("Minimalist Markdown Journal & To-Do CLI", Style.MUTED).center(68))
    print(Style.paint(f"📅 {date_display}", Style.CYAN).center(68))
    print(Style.paint("─" * 60, Style.MUTED).center(68))
    
    # 1. Resumo das Tarefas
    lines = read_todo_file()
    todos = parse_todos(lines)
    total_todos = len(todos)
    done_todos = sum(1 for t in todos if t['done'])
    pending_todos = total_todos - done_todos
    
    todo_summary = f"🎯 Todo List: {pending_todos} pendentes | {done_todos} concluídas"
    print(Style.paint(f"  {todo_summary}", Style.WHITE, bold=True))
    
    # Exibe as primeiras 3 tarefas pendentes se houver
    if pending_todos > 0:
        pendings = [t for t in todos if not t['done']][:3]
        for t in pendings:
            # Encontra o índice visível
            idx = todos.index(t) + 1
            print(f"     {Style.paint(f'{idx}.', Style.PURPLE)} {ICON_TODO_PENDING} {t['text']}")
        if pending_todos > 3:
            print(Style.paint(f"     ... e mais {pending_todos - 3} tarefas pendentes. Digite 'taskzito todo'", Style.MUTED))
    elif total_todos > 0:
        print(Style.paint("     🎉 Todas as tarefas concluídas!", Style.GREEN))
    else:
        print(Style.paint("     Nenhuma tarefa cadastrada. Adicione uma tarefa!", Style.MUTED))
        
    print()
    
    # 2. Resumo do Diário de Hoje
    print(Style.paint(f"  {ICON_JOURNAL} Journal de Hoje:", Style.WHITE, bold=True))
    
    notes = parse_today_journal()
    has_journal_today = len(notes) > 0
    
    if has_journal_today:
        for note in notes[-3:]:
            time_display = Style.paint(f"[{note['time']}]", Style.MUTED)
            highlighted_note = highlight_tags(note['text'])
            note_lines = highlighted_note.split('\n')
            print(f"     {ICON_BULLET} {time_display} {note_lines[0]}")
            indentation = " " * 18
            for extra_line in note_lines[1:]:
                print(f"{indentation}{extra_line}")
        if len(notes) > 3:
            print(Style.paint(f"     ... e mais {len(notes) - 3} notas hoje. Digite 'taskzito view'", Style.MUTED))
                    
    if not has_journal_today:
        print(Style.paint("     Nenhuma nota anotada hoje. Registre seu dia!", Style.MUTED))
        
    print(Style.paint("─" * 60, Style.MUTED).center(68))
    
    # 3. Quick Help Menu
    print(Style.paint("🚀 COMANDOS RÁPIDOS:", Style.CYAN))
    print(f"  {Style.paint('taskzito todo', Style.PURPLE, bold=True):<25} {Style.paint('Lista todas as tarefas', Style.MUTED)}")
    print(f"  {Style.paint('taskzito add <tarefa>', Style.PURPLE, bold=True):<25} {Style.paint('Adiciona uma tarefa no todo.d', Style.MUTED)}")
    print(f"  {Style.paint('taskzito toggle <id>', Style.PURPLE, bold=True):<25} {Style.paint('Marca/desmarca uma tarefa', Style.MUTED)}")
    print(f"  {Style.paint('taskzito del <id>', Style.PURPLE, bold=True):<25} {Style.paint('Remove uma tarefa', Style.MUTED)}")
    print(f"  {Style.paint('taskzito note <texto>', Style.BLUE, bold=True):<25} {Style.paint('Escreve uma nota no jornal de hoje', Style.MUTED)}")
    print(f"  {Style.paint('taskzito view', Style.BLUE, bold=True):<25} {Style.paint('Exibe o jornal do dia', Style.MUTED)}")
    print(f"  {Style.paint('taskzito report', Style.CYAN, bold=True):<25} {Style.paint('Exibe relatório de #Task e #Bug por dia', Style.MUTED)}")
    print(Style.paint("─" * 60, Style.MUTED).center(68))


# ==============================================================================
# MAIN ROUTING
# ==============================================================================
def main():
    ensure_files_exist()
    if len(sys.argv) < 2:
        show_dashboard()
        return

    command = sys.argv[1].lower()

    if command in ('help', '-h', '--help'):
        show_dashboard()
        
    elif command in ('todo', 't', 'list'):
        # Se houver subcomando para todo (ex: taskzito todo add "..." ou taskzito todo toggle 1)
        if len(sys.argv) > 2:
            sub = sys.argv[2].lower()
            if sub == 'add':
                add_todo(" ".join(sys.argv[3:]))
            elif sub == 'toggle':
                if len(sys.argv) < 4:
                    print(Style.paint("❌ Erro: Especifique o índice para fazer o toggle.", Style.RED))
                    sys.exit(1)
                try:
                    idx = int(sys.argv[3])
                    toggle_todo(idx)
                except ValueError:
                    print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            elif sub == 'edit':
                if len(sys.argv) < 4:
                    print(Style.paint("❌ Erro: Especifique o índice da tarefa para editar.", Style.RED))
                    sys.exit(1)
                try:
                    idx = int(sys.argv[3])
                    new_text = " ".join(sys.argv[4:]) if len(sys.argv) > 4 else None
                    edit_todo(idx, new_text)
                except ValueError:
                    print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            elif sub in ('del', 'delete', 'remove'):
                if len(sys.argv) < 4:
                    print(Style.paint("❌ Erro: Especifique o índice para remover.", Style.RED))
                    sys.exit(1)
                try:
                    idx = int(sys.argv[3])
                    delete_todo(idx)
                except ValueError:
                    print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            else:
                # Trata tudo após o comando como a adição de uma tarefa
                add_todo(" ".join(sys.argv[2:]))
        else:
            list_todos()
            
    elif command == 'add':
        if len(sys.argv) < 3:
            print(Style.paint("❌ Erro: Informe o texto da tarefa.", Style.RED))
            sys.exit(1)
        add_todo(" ".join(sys.argv[2:]))
        
    elif command == 'edit':
        if len(sys.argv) < 3:
            print(Style.paint("❌ Erro: Informe o número da tarefa para editar.", Style.RED))
            sys.exit(1)
        try:
            idx = int(sys.argv[2])
            new_text = " ".join(sys.argv[3:]) if len(sys.argv) > 3 else None
            edit_todo(idx, new_text)
        except ValueError:
            print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))

    elif command in ('toggle', 'check', 'uncheck', 'tk'):
        if len(sys.argv) < 3:
            print(Style.paint("❌ Erro: Informe o número da tarefa.", Style.RED))
            sys.exit(1)
        try:
            idx = int(sys.argv[2])
            toggle_todo(idx)
        except ValueError:
            print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            
    elif command in ('del', 'delete', 'remove', 'td'):
        if len(sys.argv) < 3:
            print(Style.paint("❌ Erro: Informe o número da tarefa.", Style.RED))
            sys.exit(1)
        try:
            idx = int(sys.argv[2])
            delete_todo(idx)
        except ValueError:
            print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            
    elif command in ('note', 'n', 'journal', 'j'):
        if len(sys.argv) > 2:
            sub = sys.argv[2].lower()
            if sub == 'edit':
                if len(sys.argv) < 4:
                    print(Style.paint("❌ Erro: Especifique o índice da nota para editar.", Style.RED))
                    sys.exit(1)
                try:
                    idx = int(sys.argv[3])
                    new_text = " ".join(sys.argv[4:]) if len(sys.argv) > 4 else None
                    edit_journal_note(idx, new_text)
                except ValueError:
                    print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            elif sub in ('del', 'delete', 'remove'):
                if len(sys.argv) < 4:
                    print(Style.paint("❌ Erro: Especifique o índice da nota para remover.", Style.RED))
                    sys.exit(1)
                try:
                    idx = int(sys.argv[3])
                    delete_journal_note(idx)
                except ValueError:
                    print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            else:
                add_journal_note(" ".join(sys.argv[2:]))
        else:
            list_today_journal()
            
    elif command in ('view', 'today'):
        list_today_journal()
        
    elif command in ('report', 'r', 'stats'):
        simple_mode = False
        if len(sys.argv) > 2:
            flags = [arg.lower() for arg in sys.argv[2:]]
            if '--simple' in flags or '-s' in flags:
                simple_mode = True
        generate_report(simple_mode)
        
    else:
        # Se for um comando não reconhecido, mas o usuário digitou uma frase longa,
        # pode ser que ele queira adicionar uma tarefa ou nota de forma direta?
        # É mais seguro avisar que o comando não existe e sugerir a ajuda.
        print(Style.paint(f"❌ Comando desconhecido: '{command}'", Style.RED))
        print(Style.paint("Use 'taskzito' sem argumentos para ver o dashboard e ajuda.", Style.MUTED))
        sys.exit(1)

if __name__ == "__main__":
    main()
