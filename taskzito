#!/usr/bin/env python3
import os
import sys
import re
from datetime import datetime

# ==============================================================================
# DESIGN SYSTEM & COLOR PALETTE
# ==============================================================================
class Style:
    # Cores ANSI de 256 bits para visual moderno e vibrante
    PURPLE = '\033[38;5;141m'    # Roxo pastel
    CYAN = '\033[38;5;81m'       # Ciano neon
    GREEN = '\033[38;5;120m'     # Verde vibrante
    YELLOW = '\033[38;5;222m'    # Amarelo/Laranja suave
    RED = '\033[38;5;204m'       # Vermelho/Rosa neon
    BLUE = '\033[38;5;39m'       # Azul elétrico
    MUTED = '\033[38;5;244m'      # Cinza escuro (para textos secundários)
    WHITE = '\033[38;5;255m'     # Branco puro
    
    BOLD = '\033[1m'
    UNDERLINE = '\033[4m'
    STRIKETHROUGH = '\033[9m'    # Para tarefas concluídas
    RESET = '\033[0m'
    
    @classmethod
    def paint(cls, text, color, bold=False, strike=False):
        style_codes = color
        if bold:
            style_codes += cls.BOLD
        if strike:
            style_codes += cls.STRIKETHROUGH
        return f"{style_codes}{text}{cls.RESET}"

# Ícones unicode modernos
ICON_TODO_PENDING = "⬜"
ICON_TODO_DONE = "✅"
ICON_JOURNAL = "📝"
ICON_TIME = "🕒"
ICON_CALENDAR = "📅"
ICON_TASK = "⚡"
ICON_BUG = "🐛"
ICON_REPORT = "📊"
ICON_BULLET = "▪"

# Resolve o diretório real do script (mesmo quando chamado por link simbólico)
SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))

TODO_FILE = os.getenv("TASKZITO_TODO_FILE", os.path.join(SCRIPT_DIR, "todo.d"))
JOURNAL_FILE = os.getenv("TASKZITO_JOURNAL_FILE", os.path.join(SCRIPT_DIR, "journal.md"))

def ensure_files_exist():
    """Garante que os arquivos de dados (todo.d e journal.md) existam."""
    if not os.path.exists(TODO_FILE):
        with open(TODO_FILE, 'w', encoding='utf-8') as f:
            f.write("")
    if not os.path.exists(JOURNAL_FILE):
        with open(JOURNAL_FILE, 'w', encoding='utf-8') as f:
            f.write("")

def input_with_default(prompt, default_text):
    """
    Exibe um input interativo no terminal pré-preenchido com default_text.
    Substitui quebras de linha por \\n literais para facilitar a edição em linha única.
    """
    try:
        import readline
        readline.set_startup_hook(lambda: readline.insert_text(default_text.replace('\n', '\\n')))
    except ImportError:
        pass
        
    try:
        response = input(prompt)
        return response.replace('\\n', '\n')
    finally:
        try:
            import readline
            readline.set_startup_hook()
        except ImportError:
            pass


# ==============================================================================
# HELPERS PARA TODO LIST (todo.d)
# ==============================================================================
def read_todo_file():
    """Lê o arquivo todo.d e retorna a lista de linhas."""
    if not os.path.exists(TODO_FILE):
        return []
    with open(TODO_FILE, 'r', encoding='utf-8') as f:
        return f.read().splitlines()

def write_todo_file(lines):
    """Escreve as linhas de volta no arquivo todo.d."""
    with open(TODO_FILE, 'w', encoding='utf-8') as f:
        f.write('\n'.join(lines) + '\n')

def parse_todos(lines):
    """
    Identifica quais linhas correspondem a tarefas markdown (- [ ] ou - [x]).
    Retorna uma lista de dicionários com metadados de cada tarefa encontrada:
    { 'index': idx_no_arquivo, 'done': bool, 'text': 'texto da tarefa', 'original_line': 'linha original' }
    """
    todos = []
    # Expressão regular para capturar itens markdown como - [ ] Tarefa ou - [x] Tarefa
    todo_pattern = re.compile(r'^(\s*[-*]|\d+\.)\s+\[([ xX])\]\s+(.*)$')
    
    for idx, line in enumerate(lines):
        match = todo_pattern.match(line)
        if match:
            marker, status_char, text = match.groups()
            done = status_char.lower() == 'x'
            todos.append({
                'line_idx': idx,
                'done': done,
                'text': text.strip(),
                'marker': marker,
                'original_line': line
            })
    return todos

def list_todos():
    """Exibe a lista de tarefas formatada e com índices."""
    print(Style.paint(f"\n🎯 {Style.BOLD}SUAS TAREFAS EM {TODO_FILE}{Style.RESET}", Style.CYAN))
    print(Style.paint("─" * 50, Style.MUTED))
    
    lines = read_todo_file()
    todos = parse_todos(lines)
    
    if not todos:
        print(Style.paint("  Nenhuma tarefa encontrada! Adicione com: taskzito add \"sua tarefa\"", Style.MUTED))
        print(Style.paint("─" * 50, Style.MUTED))
        return
        
    for i, todo in enumerate(todos, start=1):
        idx_str = f"{i:2d}."
        if todo['done']:
            status_icon = ICON_TODO_DONE
            todo_text = Style.paint(todo['text'], Style.MUTED, strike=True)
            display_line = f"  {Style.paint(idx_str, Style.MUTED)} {status_icon}  {todo_text}"
        else:
            status_icon = ICON_TODO_PENDING
            todo_text = Style.paint(todo['text'], Style.WHITE, bold=True)
            display_line = f"  {Style.paint(idx_str, Style.PURPLE)} {status_icon}  {todo_text}"
        print(display_line)
        
    print(Style.paint("─" * 50, Style.MUTED))
    print(Style.paint(f"  💡 Use 'taskzito toggle <numero>' para marcar/desmarcar.", Style.MUTED))

def add_todo(task_text):
    """Adiciona uma nova tarefa ao final do arquivo todo.d."""
    if not task_text.strip():
        print(Style.paint("❌ Erro: O texto da tarefa não pode ser vazio.", Style.RED))
        sys.exit(1)
        
    new_line = f"- [ ] {task_text.strip()}"
    lines = read_todo_file()
    
    # Adiciona uma quebra de linha se necessário
    lines.append(new_line)
    write_todo_file(lines)
    
    print(Style.paint(f"✨ Tarefa adicionada com sucesso!", Style.GREEN))
    print(f"   {ICON_TODO_PENDING}  {Style.paint(task_text.strip(), Style.WHITE, bold=True)}")

def toggle_todo(index_to_toggle):
    """Altera o status de uma tarefa (concluída <-> pendente) pelo índice visível."""
    lines = read_todo_file()
    todos = parse_todos(lines)
    
    if index_to_toggle < 1 or index_to_toggle > len(todos):
        print(Style.paint(f"❌ Erro: Índice {index_to_toggle} inválido. Veja as tarefas com 'taskzito todo'", Style.RED))
        sys.exit(1)
        
    # Pega o mapeamento da tarefa no arquivo original
    target_todo = todos[index_to_toggle - 1]
    line_idx = target_todo['line_idx']
    
    # Inverte o status
    new_status_char = ' ' if target_todo['done'] else 'x'
    # Reconstrói a linha preservando a indentação e o marcador original
    marker = target_todo['marker']
    text = target_todo['text']
    
    # Preserva espaços iniciais da linha original para manter indentação markdown
    original_line = target_todo['original_line']
    leading_spaces = len(original_line) - len(original_line.lstrip())
    indent = original_line[:leading_spaces]
    
    lines[line_idx] = f"{indent}{marker} [{new_status_char}] {text}"
    write_todo_file(lines)
    
    status_msg = "concluída" if new_status_char == 'x' else "marcada como pendente"
    color = Style.GREEN if new_status_char == 'x' else Style.YELLOW
    icon = ICON_TODO_DONE if new_status_char == 'x' else ICON_TODO_PENDING
    
    print(Style.paint(f"🔄 Tarefa {index_to_toggle} {status_msg}!", color))
    print(f"   {icon}  {Style.paint(text, Style.WHITE, strike=(new_status_char == 'x'))}")

def delete_todo(index_to_delete):
    """Remove uma tarefa do arquivo todo.d pelo índice visível."""
    lines = read_todo_file()
    todos = parse_todos(lines)
    
    if index_to_delete < 1 or index_to_delete > len(todos):
        print(Style.paint(f"❌ Erro: Índice {index_to_delete} inválido.", Style.RED))
        sys.exit(1)
        
    target_todo = todos[index_to_delete - 1]
    line_idx = target_todo['line_idx']
    
    # Remove a linha
    removed_text = target_todo['text']
    lines.pop(line_idx)
    write_todo_file(lines)
    
    print(Style.paint(f"🗑️  Tarefa {index_to_delete} removida do seu todo!", Style.RED))
    print(f"   {Style.paint(removed_text, Style.MUTED, strike=True)}")

def edit_todo(index_to_edit, new_text=None):
    """Edita o texto de uma tarefa mantendo seu status e marcador original."""
    lines = read_todo_file()
    todos = parse_todos(lines)
    
    if index_to_edit < 1 or index_to_edit > len(todos):
        print(Style.paint(f"❌ Erro: Índice {index_to_edit} inválido.", Style.RED))
        sys.exit(1)
        
    target_todo = todos[index_to_edit - 1]
    
    # Modo interativo se o novo texto não for fornecido na linha de comando
    if new_text is None:
        prompt = Style.paint(f"✍️  Editar tarefa {index_to_edit} (Enter para confirmar): ", Style.CYAN)
        new_text = input_with_default(prompt, target_todo['text'])
        
    if not new_text.strip():
        print(Style.paint("❌ Erro: O texto da tarefa não pode ser vazio.", Style.RED))
        sys.exit(1)
        
    line_idx = target_todo['line_idx']
    marker = target_todo['marker']
    status_char = 'x' if target_todo['done'] else ' '
    
    # Preserva espaços iniciais da linha original para manter indentação markdown
    original_line = target_todo['original_line']
    leading_spaces = len(original_line) - len(original_line.lstrip())
    indent = original_line[:leading_spaces]
    
    lines[line_idx] = f"{indent}{marker} [{status_char}] {new_text.strip()}"
    write_todo_file(lines)
    
    print(Style.paint(f"📝 Tarefa {index_to_edit} editada com sucesso!", Style.GREEN))
    icon = ICON_TODO_DONE if target_todo['done'] else ICON_TODO_PENDING
    print(f"   {icon}  {Style.paint(new_text.strip(), Style.WHITE, strike=target_todo['done'])}")


