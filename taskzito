# ==============================================================================
# MAIN ROUTING
# ==============================================================================
def main():
    ensure_files_exist()
    if len(sys.argv) < 2:
        show_dashboard()
        return

    command = sys.argv[1].lower()

    if command in ('help', '-h', '--help'):
        show_dashboard()
        
    elif command in ('todo', 't', 'list'):
        # Se houver subcomando para todo (ex: taskzito todo add "..." ou taskzito todo toggle 1)
        if len(sys.argv) > 2:
            sub = sys.argv[2].lower()
            if sub == 'add':
                add_todo(" ".join(sys.argv[3:]))
            elif sub == 'toggle':
                if len(sys.argv) < 4:
                    print(Style.paint("❌ Erro: Especifique o índice para fazer o toggle.", Style.RED))
                    sys.exit(1)
                try:
                    idx = int(sys.argv[3])
                    toggle_todo(idx)
                except ValueError:
                    print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            elif sub in ('del', 'delete', 'remove'):
                if len(sys.argv) < 4:
                    print(Style.paint("❌ Erro: Especifique o índice para remover.", Style.RED))
                    sys.exit(1)
                try:
                    idx = int(sys.argv[3])
                    delete_todo(idx)
                except ValueError:
                    print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            else:
                # Trata tudo após o comando como a adição de uma tarefa
                add_todo(" ".join(sys.argv[2:]))
        else:
            list_todos()
            
    elif command == 'add':
        if len(sys.argv) < 3:
            print(Style.paint("❌ Erro: Informe o texto da tarefa.", Style.RED))
            sys.exit(1)
        add_todo(" ".join(sys.argv[2:]))
        
    elif command in ('toggle', 'check', 'uncheck', 'tk'):
        if len(sys.argv) < 3:
            print(Style.paint("❌ Erro: Informe o número da tarefa.", Style.RED))
            sys.exit(1)
        try:
            idx = int(sys.argv[2])
            toggle_todo(idx)
        except ValueError:
            print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            
    elif command in ('del', 'delete', 'remove', 'td'):
        if len(sys.argv) < 3:
            print(Style.paint("❌ Erro: Informe o número da tarefa.", Style.RED))
            sys.exit(1)
        try:
            idx = int(sys.argv[2])
            delete_todo(idx)
        except ValueError:
            print(Style.paint("❌ Erro: O índice deve ser um número inteiro.", Style.RED))
            
    elif command in ('note', 'n', 'journal', 'j'):
        if len(sys.argv) < 3:
            # Se chamou sem texto, exibe as notas do jornal de hoje
            list_today_journal()
        else:
            add_journal_note(" ".join(sys.argv[2:]))
            
    elif command in ('view', 'today'):
        list_today_journal()
        
    elif command in ('report', 'r', 'stats'):
        simple_mode = False
        if len(sys.argv) > 2:
            flags = [arg.lower() for arg in sys.argv[2:]]
            if '--simple' in flags or '-s' in flags:
                simple_mode = True
        generate_report(simple_mode)
        
    else:
        # Se for um comando não reconhecido, mas o usuário digitou uma frase longa,
        # pode ser que ele queira adicionar uma tarefa ou nota de forma direta?
        # É mais seguro avisar que o comando não existe e sugerir a ajuda.
        print(Style.paint(f"❌ Comando desconhecido: '{command}'", Style.RED))
        print(Style.paint("Use 'taskzito' sem argumentos para ver o dashboard e ajuda.", Style.MUTED))
        sys.exit(1)

if __name__ == "__main__":
    main()
