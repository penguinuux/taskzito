def add_journal_note(note_text):
    """Anexa uma nota de texto temporal com timestamp no dia atual."""
    if not note_text.strip():
        print(Style.paint("❌ Erro: A nota não pode estar vazia.", Style.RED))
        sys.exit(1)
        
    now = datetime.now()
    today_str = now.strftime("%d/%m/%Y")
    time_str = now.strftime("%H:%M:%S")
    
    note_content = note_text.strip()
    
    # Lê conteúdo atual do jornal para verificação
    content = ""
    if os.path.exists(JOURNAL_FILE):
        with open(JOURNAL_FILE, 'r', encoding='utf-8') as f:
            content = f.read()
            
    header_today = f"# {today_str}"
    
    # Verifica se a seção de hoje já existe no arquivo
    # Uma forma limpa é verificar se o arquivo termina com a seção do dia de hoje
    # ou se ela já foi definida em algum ponto
    new_entry = f"- [{time_str}] {note_content}"
    
    # Se o arquivo estiver vazio
    if not content.strip():
        updated_content = f"{header_today}\n\n{new_entry}\n"
    else:
        # Se o header de hoje já existe, apenas adicionamos a nota no final do dia
        # Para evitar problemas se o usuário adicionar notas antigas de forma manual,
        # vamos verificar se a última ocorrência de `# YYYY-MM-DD` é de hoje.
        headers = re.findall(r'^#\s+(\d{2}/\d{2}/\d{4})', content, re.MULTILINE)
        
        if headers and headers[-1] == today_str:
            # O dia atual é o último do jornal. Apenas anexamos
            # Garante que termine com nova linha para formatar bem
            if not content.endswith('\n'):
                content += '\n'
            updated_content = f"{content}{new_entry}\n"
        else:
            # O dia atual ainda não foi criado ou o arquivo está desordenado.
            # Adicionamos uma nova seção de dia ao final
            if not content.endswith('\n'):
                content += '\n'
            if content.strip():
                updated_content = f"{content}\n{header_today}\n\n{new_entry}\n"
            else:
                updated_content = f"{header_today}\n\n{new_entry}\n"
                
    with open(JOURNAL_FILE, 'w', encoding='utf-8') as f:
        f.write(updated_content)
        
    # Destaca tags encontradas na nota na hora de exibir confirmação
    highlighted_note = highlight_tags(new_entry)
    print(Style.paint(f"📝 Nota registrada no jornal com sucesso!", Style.GREEN))
    print(f"   {highlighted_note}")

def highlight_tags(text):
    """Pinta as hashtags de Task e Bug com cores vibrantes para exibição no terminal."""
    # Colore #Task123 de Roxo e #Bug123 de Vermelho
    text = re.sub(r'(#Task\w+)', lambda m: Style.paint(m.group(1), Style.PURPLE, bold=True), text, flags=re.IGNORECASE)
    text = re.sub(r'(#Bug\w+)', lambda m: Style.paint(m.group(1), Style.RED, bold=True), text, flags=re.IGNORECASE)
    # Colore outras hashtags gerais se existirem de azul
    text = re.sub(r'(?<!\S)#((?!Task\w+|Bug\w+)\w+)', lambda m: Style.paint("#" + m.group(1), Style.BLUE), text, flags=re.IGNORECASE)
    return text

def parse_today_journal():
    """
    Lê o journal.md e extrai todas as notas do dia de hoje.
    Retorna uma lista de dicionários com metadados de cada nota.
    """
    if not os.path.exists(JOURNAL_FILE):
        return []
    with open(JOURNAL_FILE, 'r', encoding='utf-8') as f:
        lines = f.read().splitlines()
        
    today_str = datetime.now().strftime("%d/%m/%Y")
    in_today_section = False
    notes = []
    
    for idx, line in enumerate(lines):
        if line.strip().startswith('# '):
            date_match = re.match(r'^#\s+(\d{2}/\d{2}/\d{4})', line.strip())
            if date_match:
                current_date = date_match.group(1)
                in_today_section = (current_date == today_str)
            else:
                in_today_section = False
            continue
            
        if in_today_section:
            note_match = re.match(r'^\s*[-*]\s+\[(\d{2}:\d{2}:\d{2})\]\s+(.*)$', line)
            if note_match:
                time_str, text = note_match.groups()
                text_clean = text.replace('\\n', '\n')
                notes.append({
                    'line_indices': [idx],
                    'time': time_str,
                    'text': text_clean,
                    'original_lines': [line]
                })
            else:
                if notes:
                    line_clean = line.replace('\\n', '\n')
                    notes[-1]['line_indices'].append(idx)
                    notes[-1]['text'] += "\n" + line_clean
                    notes[-1]['original_lines'].append(line)
    return notes

def edit_journal_note(index_to_edit, new_text=None):
    """Edita uma nota do diário de hoje pelo índice de exibição."""
    if not os.path.exists(JOURNAL_FILE):
        print(Style.paint("❌ Erro: Nenhum jornal encontrado.", Style.RED))
        sys.exit(1)
        
    with open(JOURNAL_FILE, 'r', encoding='utf-8') as f:
        lines = f.read().splitlines()
        
    notes = parse_today_journal()
    
    if index_to_edit < 1 or index_to_edit > len(notes):
        print(Style.paint(f"❌ Erro: Índice de nota {index_to_edit} inválido para hoje.", Style.RED))
        sys.exit(1)
        
    target_note = notes[index_to_edit - 1]
    
    # Modo interativo se o novo texto não for fornecido na linha de comando
    if new_text is None:
        prompt = Style.paint(f"✍️  Editar nota {index_to_edit} (Enter para confirmar): ", Style.CYAN)
        new_text = input_with_default(prompt, target_note['text'])
        
    if not new_text.strip():
        print(Style.paint("❌ Erro: O texto da nota não pode estar vazio.", Style.RED))
        sys.exit(1)
        
    time_str = target_note['time']
    
    original_first_line = target_note['original_lines'][0]
    leading_spaces = len(original_first_line) - len(original_first_line.lstrip())
    indent = original_first_line[:leading_spaces]
    
    new_text_clean = new_text.strip().replace('\\n', '\n')
    raw_lines = new_text_clean.split('\n')
    
    new_lines_to_insert = []
    new_lines_to_insert.append(f"{indent}- [{time_str}] {raw_lines[0]}")
    for extra_line in raw_lines[1:]:
        new_lines_to_insert.append(extra_line)
        
    indices_to_remove = sorted(target_note['line_indices'])
    first_idx = indices_to_remove[0]
    
    for idx in sorted(indices_to_remove[1:], reverse=True):
        lines.pop(idx)
        
    lines.pop(first_idx)
    for i, new_line in enumerate(new_lines_to_insert):
        lines.insert(first_idx + i, new_line)
        
    with open(JOURNAL_FILE, 'w', encoding='utf-8') as f:
        f.write('\n'.join(lines) + '\n')
        
    print(Style.paint(f"📝 Nota {index_to_edit} do diário editada com sucesso!", Style.GREEN))
    highlighted_note = highlight_tags(new_text_clean)
    note_lines = highlighted_note.split('\n')
    time_display = Style.paint(f"[{time_str}]", Style.MUTED)
    print(f"   {time_display} {note_lines[0]}")
    indentation = " " * (len("[HH:MM:SS]") + 4)
    for extra_line in note_lines[1:]:
        print(f"{indentation}{extra_line}")

def delete_journal_note(index_to_delete):
    """Remove uma nota do diário de hoje pelo índice de exibição."""
    if not os.path.exists(JOURNAL_FILE):
