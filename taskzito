def show_dashboard():
    """Exibe um painel de controle premium consolidando o status de hoje."""
    now = datetime.now()
    date_display = now.strftime("%A, %d de %B de %Y - %H:%M:%S")
    # Traduz dia da semana de forma simples se possível (opcional, mantendo portabilidade rápida)
    weekdays_pt = {
        "Monday": "Segunda-feira", "Tuesday": "Terça-feira", "Wednesday": "Quarta-feira",
        "Thursday": "Quinta-feira", "Friday": "Sexta-feira", "Saturday": "Sábado", "Sunday": "Domingo"
    }
    months_pt = {
        "January": "Janeiro", "February": "Fevereiro", "March": "Março", "April": "Abril",
        "May": "Maio", "June": "Junho", "July": "Julho", "August": "Agosto",
        "September": "Setembro", "October": "Outubro", "November": "Novembro", "December": "Dezembro"
    }
    
    eng_weekday = now.strftime("%A")
    eng_month = now.strftime("%B")
    
    pt_weekday = weekdays_pt.get(eng_weekday, eng_weekday)
    pt_month = months_pt.get(eng_month, eng_month)
    date_display = f"{pt_weekday}, {now.day} de {pt_month} de {now.year}"
    
    print("\n" + Style.paint("  ⚡  TASKZITO  ⚡  ", Style.PURPLE, bold=True).center(68))
    print(Style.paint("Minimalist Markdown Journal & To-Do CLI", Style.MUTED).center(68))
    print(Style.paint(f"📅 {date_display}", Style.CYAN).center(68))
    print(Style.paint("─" * 60, Style.MUTED).center(68))
    
    # 1. Resumo das Tarefas
    lines = read_todo_file()
    todos = parse_todos(lines)
    total_todos = len(todos)
    done_todos = sum(1 for t in todos if t['done'])
    pending_todos = total_todos - done_todos
    
    todo_summary = f"🎯 Todo List: {pending_todos} pendentes | {done_todos} concluídas"
    print(Style.paint(f"  {todo_summary}", Style.WHITE, bold=True))
    
    # Exibe as primeiras 3 tarefas pendentes se houver
    if pending_todos > 0:
        pendings = [t for t in todos if not t['done']][:3]
        for t in pendings:
            # Encontra o índice visível
            idx = todos.index(t) + 1
            print(f"     {Style.paint(f'{idx}.', Style.PURPLE)} {ICON_TODO_PENDING} {t['text']}")
        if pending_todos > 3:
            print(Style.paint(f"     ... e mais {pending_todos - 3} tarefas pendentes. Digite 'taskzito todo'", Style.MUTED))
    elif total_todos > 0:
        print(Style.paint("     🎉 Todas as tarefas concluídas!", Style.GREEN))
    else:
        print(Style.paint("     Nenhuma tarefa cadastrada. Adicione uma tarefa!", Style.MUTED))
        
    print()
    
    # 2. Resumo do Diário de Hoje
    print(Style.paint(f"  {ICON_JOURNAL} Journal de Hoje:", Style.WHITE, bold=True))
    today_str = now.strftime("%Y-%m-%d")
    
    has_journal_today = False
    if os.path.exists(JOURNAL_FILE):
        with open(JOURNAL_FILE, 'r', encoding='utf-8') as f:
            content = f.read()
        pattern = rf"(^#\s+{today_str}\s*\n.*?(?=\n#\s|\Z))"
        match = re.search(pattern, content, re.MULTILINE | re.DOTALL)
        if match:
            section = match.group(1)
            journal_lines = [l.strip().lstrip('- ').strip() for l in section.splitlines() if l.strip().startswith('- [')]
            if journal_lines:
                has_journal_today = True
                # Exibe as últimas 3 notas de hoje
                for line in journal_lines[-3:]:
                    print(f"     {ICON_BULLET} {highlight_tags(line)}")
                if len(journal_lines) > 3:
                    print(Style.paint(f"     ... e mais {len(journal_lines) - 3} notas hoje. Digite 'taskzito view'", Style.MUTED))
                    
    if not has_journal_today:
        print(Style.paint("     Nenhuma nota anotada hoje. Registre seu dia!", Style.MUTED))
        
    print(Style.paint("─" * 60, Style.MUTED).center(68))
    
    # 3. Quick Help Menu
    print(Style.paint("🚀 COMANDOS RÁPIDOS:", Style.CYAN))
    print(f"  {Style.paint('taskzito todo', Style.PURPLE, bold=True):<25} {Style.paint('Lista todas as tarefas', Style.MUTED)}")
    print(f"  {Style.paint('taskzito add <tarefa>', Style.PURPLE, bold=True):<25} {Style.paint('Adiciona uma tarefa no todo.d', Style.MUTED)}")
    print(f"  {Style.paint('taskzito toggle <id>', Style.PURPLE, bold=True):<25} {Style.paint('Marca/desmarca uma tarefa', Style.MUTED)}")
    print(f"  {Style.paint('taskzito del <id>', Style.PURPLE, bold=True):<25} {Style.paint('Remove uma tarefa', Style.MUTED)}")
    print(f"  {Style.paint('taskzito note <texto>', Style.BLUE, bold=True):<25} {Style.paint('Escreve uma nota no jornal de hoje', Style.MUTED)}")
