# HELPERS PARA JOURNAL (journal.md)
# ==============================================================================
def add_journal_note(note_text):
    """Anexa uma nota de texto temporal com timestamp no dia atual."""
    if not note_text.strip():
        print(Style.paint("❌ Erro: A nota não pode estar vazia.", Style.RED))
        sys.exit(1)
        
    now = datetime.now()
    today_str = now.strftime("%Y-%m-%d")
    time_str = now.strftime("%H:%M:%S")
    
    note_content = note_text.strip()
    
    # Lê conteúdo atual do jornal para verificação
    content = ""
    if os.path.exists(JOURNAL_FILE):
        with open(JOURNAL_FILE, 'r', encoding='utf-8') as f:
            content = f.read()
            
    header_today = f"# {today_str}"
    
    # Verifica se a seção de hoje já existe no arquivo
    # Uma forma limpa é verificar se o arquivo termina com a seção do dia de hoje
    # ou se ela já foi definida em algum ponto
    new_entry = f"- [{time_str}] {note_content}"
    
    # Se o arquivo estiver vazio
    if not content.strip():
        updated_content = f"{header_today}\n\n{new_entry}\n"
    else:
        # Se o header de hoje já existe, apenas adicionamos a nota no final do dia
        # Para evitar problemas se o usuário adicionar notas antigas de forma manual,
        # vamos verificar se a última ocorrência de `# YYYY-MM-DD` é de hoje.
        headers = re.findall(r'^#\s+(\d{4}-\d{2}-\d{2})', content, re.MULTILINE)
        
        if headers and headers[-1] == today_str:
            # O dia atual é o último do jornal. Apenas anexamos
            # Garante que termine com nova linha para formatar bem
            if not content.endswith('\n'):
                content += '\n'
            updated_content = f"{content}{new_entry}\n"
        else:
            # O dia atual ainda não foi criado ou o arquivo está desordenado.
            # Adicionamos uma nova seção de dia ao final
            if not content.endswith('\n'):
                content += '\n'
            if content.strip():
                updated_content = f"{content}\n{header_today}\n\n{new_entry}\n"
            else:
                updated_content = f"{header_today}\n\n{new_entry}\n"
                
    with open(JOURNAL_FILE, 'w', encoding='utf-8') as f:
        f.write(updated_content)
        
    # Destaca tags encontradas na nota na hora de exibir confirmação
    highlighted_note = highlight_tags(new_entry)
    print(Style.paint(f"📝 Nota registrada no jornal com sucesso!", Style.GREEN))
    print(f"   {highlighted_note}")

def highlight_tags(text):
    """Pinta as hashtags de Task e Bug com cores vibrantes para exibição no terminal."""
    # Colore #Task123 de Roxo e #Bug123 de Vermelho
    text = re.sub(r'(#Task\w+)', lambda m: Style.paint(m.group(1), Style.PURPLE, bold=True), text, flags=re.IGNORECASE)
    text = re.sub(r'(#Bug\w+)', lambda m: Style.paint(m.group(1), Style.RED, bold=True), text, flags=re.IGNORECASE)
    # Colore outras hashtags gerais se existirem de azul
    text = re.sub(r'(?<!\S)#((?!Task\w+|Bug\w+)\w+)', lambda m: Style.paint("#" + m.group(1), Style.BLUE), text, flags=re.IGNORECASE)
    return text

def list_today_journal():
    """Mostra as notas inseridas hoje no journal."""
    now = datetime.now()
    today_str = now.strftime("%Y-%m-%d")
    
    print(Style.paint(f"\n📖 {Style.BOLD}NOTAS DO DIÁRIO DE HOJE ({today_str}){Style.RESET}", Style.CYAN))
    print(Style.paint("─" * 50, Style.MUTED))
    
    if not os.path.exists(JOURNAL_FILE):
        print(Style.paint("  Nenhuma nota registrada ainda no jornal. Use: taskzito note \"sua nota\"", Style.MUTED))
        print(Style.paint("─" * 50, Style.MUTED))
        return
        
    with open(JOURNAL_FILE, 'r', encoding='utf-8') as f:
        content = f.read()
        
    # Vamos extrair apenas a seção de hoje
    # A seção começa com '# 2026-07-07' e vai até o próximo '#' ou fim do arquivo
    pattern = rf"(^#\s+{today_str}\s*\n.*?(?=\n#\s|\Z))"
    match = re.search(pattern, content, re.MULTILINE | re.DOTALL)
    
    if not match:
        print(Style.paint("  Nenhuma nota registrada hoje ainda. Use: taskzito note \"sua nota\"", Style.MUTED))
        print(Style.paint("─" * 50, Style.MUTED))
        return
        
    section = match.group(1)
    lines = section.splitlines()[1:]  # ignora o header # YYYY-MM-DD
    
    has_notes = False
    for line in lines:
        if line.strip().startswith('- ['):
            has_notes = True
            # Limpa o marcador markdown e colore tags
            clean_line = line.strip().lstrip('- ').strip()
            print(f"  {ICON_BULLET} {highlight_tags(clean_line)}")
            
    if not has_notes:
        print(Style.paint("  Seção do dia criada, mas sem notas registradas.", Style.MUTED))
        
    print(Style.paint("─" * 50, Style.MUTED))


# ==============================================================================
# REPORTING ENGINE (Relatório por dia e tags)
# ==============================================================================
def parse_journal_for_report():
    """
    Lê o journal.md e extrai todas as tags do tipo #Task e #Bug.
    Retorna uma estrutura organizada:
    {
       'YYYY-MM-DD': {
           '#Task12345': [ (timestamp, nota_completa), ... ],
           '#Bug999': [ ... ]
       }
    }
    """
    if not os.path.exists(JOURNAL_FILE):
        return {}
        
    with open(JOURNAL_FILE, 'r', encoding='utf-8') as f:
        content = f.read()
        
    report_data = {}
    
    # Divide o arquivo em seções por dia
    # Cada seção começa com um cabeçalho `# YYYY-MM-DD`
    day_sections = re.split(r'^#\s+(\d{4}-\d{2}-\d{2})', content, flags=re.MULTILINE)
    
    # O primeiro elemento é o que vem antes do primeiro header (normalmente vazio ou cabeçalho do arquivo)
    # Depois, os elementos vêm em pares: (data, texto da seção)
    if len(day_sections) > 1:
        for i in range(1, len(day_sections), 2):
            date_str = day_sections[i].strip()
            section_text = day_sections[i+1]
            
            # Procura linhas com o padrão de notas do diário: - [HH:MM:SS] Texto da nota
            note_lines = re.findall(r'^\s*[-*]\s+\[(\d{2}:\d{2}:\d{2})\]\s+(.*)$', section_text, re.MULTILINE)
            
            for timestamp, note_text in note_lines:
                # Procura por todas as hashtags de Tasks e Bugs
                # Captura tags case-insensitive, mas as padroniza para visualização limpa
                tags = re.findall(r'#(Task\w+|Bug\w+)', note_text, re.IGNORECASE)
                
                for tag in tags:
                    # Normaliza a grafia para manter consistência no agrupamento (ex: #Task42282 -> #Task42282)
                    # Mantém o caso original do usuário, mas capitaliza a primeira letra de Task/Bug
                    tag_type = "Task" if tag.lower().startswith("task") else "Bug"
                    tag_id = tag[len(tag_type):]
                    normalized_tag = f"#{tag_type}{tag_id}"
                    
                    if date_str not in report_data:
                        report_data[date_str] = {}
                    if normalized_tag not in report_data[date_str]:
                        report_data[date_str][normalized_tag] = []
                        
                    # Remove a própria hashtag do texto para não ficar redundante no relatório,
                    # ou mantém para clareza? Geralmente, tirar a hashtag que já é o título do grupo
                    # deixa o relatório muito mais limpo e premium. Vamos manter o texto mas
                    # pintar o timestamp.
                    report_data[date_str][normalized_tag].append((timestamp, note_text.strip()))
                    
    return report_data

def generate_report(simple=False):
    """Gera e exibe um relatório de tasks e bugs resolvidos por dia."""
    report_data = parse_journal_for_report()
    
    if not report_data:
        if simple:
            print("Nenhum registro de #Task ou #Bug encontrado.")
        else:
            print(Style.paint(f"\n{ICON_REPORT} {Style.BOLD}RELATÓRIO DE TASKS E BUGS EXECUTADOS{Style.RESET}", Style.CYAN))
            print(Style.paint("═" * 60, Style.CYAN))
            print(Style.paint("  Nenhum registro de #Task ou #Bug encontrado em seu jornal.", Style.MUTED))
            print(Style.paint("  Para gerar um relatório, marque suas notas no diário. Exemplo:", Style.MUTED))
            print(Style.paint(f"  taskzito note \"Finalizado o setup do banco de dados #Task42282\"", Style.YELLOW))
            print(Style.paint("═" * 60, Style.CYAN))
        return
        
    sorted_dates = sorted(report_data.keys())
    
    if simple:
        for date_str in sorted_dates:
            tags_dict = report_data[date_str]
            sorted_tags = sorted(tags_dict.keys(), key=lambda t: (0 if "Task" in t else 1, t))
            tags_str = ", ".join(sorted_tags)
            print(f"{date_str}: {tags_str}")
    else:
        print(Style.paint(f"\n{ICON_REPORT} {Style.BOLD}RELATÓRIO DE TASKS E BUGS EXECUTADOS{Style.RESET}", Style.CYAN))
        print(Style.paint("═" * 60, Style.CYAN))
        
        for date_str in sorted_dates:
            print(f"\n{ICON_CALENDAR} {Style.paint(date_str, Style.WHITE, bold=True)}")
            print(Style.paint("  " + "─" * 45, Style.MUTED))
            
            tags_dict = report_data[date_str]
            sorted_tags = sorted(tags_dict.keys(), key=lambda t: (0 if "Task" in t else 1, t))
            
            for tag in sorted_tags:
                is_bug = "Bug" in tag
                tag_color = Style.RED if is_bug else Style.PURPLE
                tag_icon = ICON_BUG if is_bug else ICON_TASK
                
                print(f"    {tag_icon} {Style.paint(tag, tag_color, bold=True)}")
                
                for timestamp, note_text in tags_dict[tag]:
                    time_display = Style.paint(f"[{timestamp}]", Style.MUTED)
                    highlighted_note = highlight_tags(note_text)
                    print(f"      {ICON_TIME} {time_display} {highlighted_note}")
            print()
            
        print(Style.paint("═" * 60, Style.CYAN))


